# Get these from https://my.telegram.org
TG_API_ID=
TG_API_HASH=

# Folder where Telethon .session files are stored
SESSIONS_DIR=./sessions

# SQLite DB path
DB_URL=sqlite+aiosqlite:///./app.db

# Default rate limit window (seconds) between bulk actions
RATE_MIN=2
RATE_MAX=4

# CORS (only used when running frontend dev server on 5173)
ALLOWED_ORIGIN=http://localhost:5173

# ===== ACCESS PASSWORD (REQUIRED) =====
# Plain password for the login page. Min 12 chars recommended.
# Backend hashes it with bcrypt on first request, never stored in plain anywhere.
APP_PASSWORD=change-me-to-a-long-strong-password

# Random secret for signing the session cookie. 64+ random chars.
# If you change this, all existing sessions are invalidated.
SESSION_SECRET=please-replace-with-a-long-random-string-at-least-48-chars

# How many days the login cookie stays valid
SESSION_DAYS=14

# Login rate limit: max attempts per window
LOGIN_MAX_ATTEMPTS=5
LOGIN_WINDOW_MIN=15
